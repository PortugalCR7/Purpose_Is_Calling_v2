# Copy to .env.local and fill in real values. Never commit .env.local.

# Higgsfield MCP connector — used for stills/video generation and the
# asset pipeline described in film/prompt-bible.md
HIGGSFIELD_API_KEY=

# Anthropic API — used by the Inquiry's server-side reflection route
# (see AGENTS.md section 5 for the rules governing this call)
ANTHROPIC_API_KEY=

# Calendly (or equivalent) — used to prefill the Discovery Call notes
# field from the Inquiry's completed reflection
CALENDLY_WEBHOOK_URL=
